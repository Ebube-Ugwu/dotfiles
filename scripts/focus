#!/usr/bin/env bash

if [[ -z $1 ]]; then
  echo "Usage: $0 <window-class-name>"
  exit 1
fi

program=$1

# 1. Use awk to scan column 3 (WM_CLASS) for exact or partial application matches
# 2. Extract the Window ID (column 1) to pass cleanly to wmctrl
window_id=$(wmctrl -lx | awk -v prog="$program" '
    tolower($3) ~ tolower(prog) { print $1; exit }
')

if [[ -n "$window_id" ]]; then
  wmctrl -i -a "$window_id"
else
  echo "No application matching '$program' found running in WM_CLASS."
  exit 1
fi
